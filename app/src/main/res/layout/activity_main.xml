<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".MainActivity"
    android:background="@drawable/degradee_login_background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:orientation="vertical"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent">

        <ImageView
            android:id="@+id/profile"
            android:layout_width="160dp"
            android:layout_height="160dp"
            app:srcCompat="@drawable/profile_circle_svg"
            tools:layout_editor_absoluteX="137dp"
            tools:layout_editor_absoluteY="139dp" />


        <EditText
            android:id="@+id/editTextEmailInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Login"
            android:textColor="@color/white"
            android:textColorHint="@color/white"
            android:textSize="20sp"
            android:background="@drawable/text_edit_pill_shape"
            android:padding="18dp"
            android:inputType="textEmailAddress"
            android:layout_marginTop="32dp"
            />

        <EditText
            android:id="@+id/editTextSenhaInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Senha"
            android:textColor="@color/white"
            android:textColorHint="@color/white"
            android:textSize="20sp"
            android:background="@drawable/text_edit_pill_shape"
            android:padding="18dp"
            android:inputType="textPassword"
            android:layout_marginTop="32dp"/>

        <Button
            android:id="@+id/buttonConfirmacaoLogin"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:text="Login"
            android:backgroundTint="@color/white"
            android:textColor="@color/black"
            android:padding="18dp"
            />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:text="Ou entre com uma rede social"
            android:textSize="18sp"
            android:textColor="@color/white"
            android:layout_marginTop="32dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginTop="8dp">


            <ImageView
                android:layout_width="75dp"
                android:layout_height="75dp"
                android:src="@drawable/facebook_svg"
                android:layout_margin="8dp"/>

            <ImageView
                android:layout_width="75dp"
                android:layout_height="75dp"
                android:src="@drawable/linkedin_round_svg"
                android:layout_margin="8dp"/>

        </LinearLayout>
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>